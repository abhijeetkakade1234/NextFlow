{
  "name": "nextflow-temp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --raw --kill-others \"npm:dev:next\" \"npm:dev:trigger\"",
    "dev:next": "next dev",
    "dev:trigger": "npx trigger.dev@4.4.3 dev --env-file .env.local",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.6",
    "@google/generative-ai": "^0.24.1",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@tanstack/react-query": "^5.91.3",
    "@trigger.dev/sdk": "4.4.3",
    "@xyflow/react": "^12.10.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "execa": "^9.6.1",
    "immer": "^11.1.4",
    "ipaddr.js": "^2.3.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "transloadit": "^4.7.4",
    "ws": "^8.19.0",
    "zod": "^3.25.76",
    "zundo": "^2.3.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@trigger.dev/build": "4.4.3",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.8.1",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
